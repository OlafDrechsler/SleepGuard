require "fileutils"

default_platform(:android)

# --- Konfiguration -----------------------------------------------------------

# Locales, die F-Droid nutzt, die Google Play aber NICHT unterstuetzt.
UNSUPPORTED_PLAY_LOCALES = %w[ga mt].freeze

# --- Pfad-Aufloesung (CWD-unabhaengig) ---------------------------------------
# WICHTIG: fastlane fuehrt Lanes u. U. mit dem "fastlane/"-Ordner als
# Arbeitsverzeichnis aus, waehrend supply seine Pfade gegen die Repo-Wurzel
# aufloest. Relative Pfade in eigenem Ruby-Code sind daher unzuverlaessig ->
# hier immer zu absoluten Pfaden aufloesen.

def resolve_metadata_dir
  ["fastlane/metadata/android", "metadata/android"]
    .map { |p| File.expand_path(p) }
    .find { |p| Dir.exist?(p) }
end

def manifest_path(stash_dir)
  File.join(stash_dir, "manifest.txt")
end

# Verschiebt <metadata_dir>/<rel> nach <stash_dir>/<rel> (Struktur bleibt erhalten,
# daher keine Namenskollision zwischen mehreren "changelogs"-Ordnern).
def stash_rel(rel, metadata_dir, stash_dir)
  src = File.join(metadata_dir, rel)
  return unless File.exist?(src)
  dst = File.join(stash_dir, rel)
  FileUtils.mkdir_p(File.dirname(dst))
  FileUtils.mv(src, dst)
  FileUtils.mkdir_p(stash_dir)
  File.open(manifest_path(stash_dir), "a") { |f| f.puts(rel) }
  UI.message("↪  #{rel} temporaer ausgeklammert")
end

def restore_stash(metadata_dir, stash_dir)
  mf = manifest_path(stash_dir)
  return unless File.exist?(mf)
  File.readlines(mf).map(&:strip).reject(&:empty?).each do |rel|
    src = File.join(stash_dir, rel)
    next unless File.exist?(src)
    dst = File.join(metadata_dir, rel)
    FileUtils.mkdir_p(File.dirname(dst))
    FileUtils.mv(src, dst)
    UI.message("↩  #{rel} wiederhergestellt")
  end
  FileUtils.rm_rf(stash_dir)
end

# Findet die gebaute signierte AAB (CWD-unabhaengig).
def find_release_aab
  ["app/build/outputs/bundle/release/app-release.aab",
   "../app/build/outputs/bundle/release/app-release.aab"]
    .map { |p| File.expand_path(p) }
    .find { |p| File.exist?(p) }
end

# --- Lanes -------------------------------------------------------------------

platform :android do
  desc "Store-Texte + Grafiken zu Google Play hochladen (nur Metadaten, keine App-Datei)."
  desc "Standard = nur Validierung. Fuer den echten Upload:  fastlane upload_metadata validate:false"
  lane :upload_metadata do |options|
    # UTF-8 erzwingen – wichtig fuer CJK/Kyrillisch/Griechisch/Umlaute.
    ENV["LANG"]   = "en_US.UTF-8"
    ENV["LC_ALL"] = "en_US.UTF-8"

    # true = nur pruefen (nichts wird gesendet); false = wirklich hochladen.
    validate = options.fetch(:validate, true)

    # Track + Versionscode eines EXISTIERENDEN Releases. supply koppelt den
    # (app-weiten) Store-Listing-Upload leider an ein Release. Ohne passenden
    # Track/Versionscode -> "Could not find release for version code ''".
    #   fastlane upload_metadata track:"alpha" version_code:8
    track        = options.fetch(:track, "production")
    version_code = options[:version_code]&.to_s
    UI.user_error!("Bitte version_code:<Nummer> und ggf. track:\"<Track-Name>\" angeben " \
                   "(Versionscode eines vorhandenen Releases).") if version_code.nil? || version_code.empty?

    metadata_dir = resolve_metadata_dir
    UI.user_error!("Metadaten-Ordner nicht gefunden (cwd=#{Dir.pwd}).") if metadata_dir.nil?
    stash_dir = File.expand_path(File.join(metadata_dir, "..", "..", ".play_locale_stash"))

    # Reste eines evtl. abgebrochenen Laufs zuerst zuruecklegen.
    restore_stash(metadata_dir, stash_dir)

    # 1) Von Play nicht unterstuetzte Locales ausklammern.
    UNSUPPORTED_PLAY_LOCALES.each { |loc| stash_rel(loc, metadata_dir, stash_dir) }
    # 2) Changelog-Ordner ausklammern: Release-Notes brauchen ein Release/Versionscode.
    Dir.glob(File.join(metadata_dir, "*", "changelogs")).each do |abs|
      stash_rel(abs.sub(metadata_dir + File::SEPARATOR, ""), metadata_dir, stash_dir)
    end

    # HARTE Absicherung: ga/mt duerfen jetzt NICHT mehr im Metadaten-Ordner liegen,
    # sonst wuerde supply sie an Play schicken ("<loc> - Invalid request"). Lieber
    # abbrechen als einen fehlerhaften Upload ausloesen.
    still_there = UNSUPPORTED_PLAY_LOCALES.select { |loc| Dir.exist?(File.join(metadata_dir, loc)) }
    unless still_there.empty?
      restore_stash(metadata_dir, stash_dir)
      UI.user_error!("Konnte #{still_there.join(', ')} nicht ausklammern (in #{metadata_dir}). " \
                     "Abbruch, um keinen Invalid-request-Upload auszuloesen.")
    end

    begin
      supply(
        metadata_path:          metadata_dir,   # explizit, damit alles auf denselben Ordner zeigt
        track:                  track,
        version_code:           version_code,
        validate_only:          validate,
        skip_upload_apk:        true,           # reiner Metadaten-Upload
        skip_upload_aab:        true,
        skip_upload_changelogs: true
      )
    ensure
      # Laeuft auch, wenn supply einen Fehler wirft.
      restore_stash(metadata_dir, stash_dir)
    end

    if validate
      UI.success("Validierung ok. Echter Upload:  bundle exec fastlane upload_metadata track:\"#{track}\" version_code:#{version_code} validate:false")
    else
      UI.success("Metadaten hochgeladen. Sichtbar unter 'Veroeffentlichungen – Uebersicht' (muss zur Ueberpruefung eingereicht werden).")
    end
  end

  desc "Neues Release (signierte AAB) in einen Play-Track hochladen, inkl. Release-Notes."
  desc "Vorher bauen:  .\\gradlew.bat bundleRelease"
  desc "Standard: Track 'alpha' (geschlossener Test), Status 'completed'."
  desc "Beispiel:  fastlane upload_release track:\"alpha\" status:completed"
  lane :upload_release do |options|
    ENV["LANG"]   = "en_US.UTF-8"
    ENV["LC_ALL"] = "en_US.UTF-8"

    track  = options.fetch(:track, "alpha")
    status = options.fetch(:status, "completed")   # completed = nach Google-Review im Track aktiv
    aab    = options[:aab] ? File.expand_path(options[:aab]) : find_release_aab
    unless aab && File.exist?(aab.to_s)
      UI.user_error!("AAB nicht gefunden. Zuerst bauen:  gradlew bundleRelease " \
                     "(erwartet app/build/outputs/bundle/release/app-release.aab).")
    end

    metadata_dir = resolve_metadata_dir
    UI.user_error!("Metadaten-Ordner nicht gefunden (cwd=#{Dir.pwd}).") if metadata_dir.nil?
    stash_dir = File.expand_path(File.join(metadata_dir, "..", "..", ".play_locale_stash"))

    # ga/mt defensiv ausklammern (falls supply Locales fuer Release-Notes durchgeht).
    restore_stash(metadata_dir, stash_dir)
    UNSUPPORTED_PLAY_LOCALES.each { |loc| stash_rel(loc, metadata_dir, stash_dir) }

    begin
      supply(
        metadata_path:           metadata_dir,
        track:                   track,
        aab:                     aab,
        release_status:          status,
        skip_upload_apk:         true,
        skip_upload_metadata:    true,    # Store-Listing ist bereits aktuell
        skip_upload_images:      true,
        skip_upload_screenshots: true,
        skip_upload_changelogs:  false    # Release-Notes aus changelogs/<versionCode>.txt (9.txt)
      )
    ensure
      restore_stash(metadata_dir, stash_dir)
    end

    UI.success("Release '#{File.basename(aab)}' auf Track '#{track}' hochgeladen (Status: #{status}).")
  end
end
