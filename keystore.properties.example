# Vorlage fuer die Release-Signierung.
#
# 1. Erzeuge einmalig einen Keystore (Passwoerter frei waehlen), in PowerShell/cmd
#    im Projekt-Stammverzeichnis, alles in EINER Zeile:
#
#    keytool -genkey -v -keystore sleepguard-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias sleepguard
#
# 2. Kopiere diese Datei zu  keystore.properties  (ohne .example)
#    und trage deine echten Werte ein.
# 3. keystore.properties und die .jks-Datei NIEMALS ins Git einchecken
#    (sind bereits in .gitignore ausgeschlossen).
# 4. Bewahre den Keystore sicher auf — ohne ihn kannst du keine Updates
#    mehr signieren!

storeFile=../sleepguard-release.jks
storePassword=CHANGE_ME
keyAlias=sleepguard
keyPassword=CHANGE_ME
