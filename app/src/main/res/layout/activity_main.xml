<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- App-Titel -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FF333333"
            android:layout_marginBottom="32dp" />

        <!-- Status-Anzeige -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_stopped"
            android:textSize="16sp"
            android:textColor="#FF888888"
            android:layout_marginBottom="32dp" />

        <!-- Intervall -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_interval"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnIntervalMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="-"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/intervalText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="5"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnIntervalPlus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="+"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- Timeout -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_timeout"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnTimeoutMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="-"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/timeoutText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="15"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnTimeoutPlus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="+"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- Position -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_position"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/positionSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="32dp"
            android:background="@android:drawable/btn_dropdown" />

        <!-- Start/Stop Button -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="@string/btn_start"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- Sprachauswahl (unterer Bildschirmrand) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_language"
            android:textSize="14sp"
            android:textColor="#FF666666"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/languageSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:background="@android:drawable/btn_dropdown" />

        <!-- Freiwillige Spende: oeffnet einen externen Link im Browser.
             Keine Gegenleistung -> gilt als Spende, kein In-App-Kauf. -->
        <Button
            android:id="@+id/btnSupport"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_support"
            android:textColor="#FF1565C0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
