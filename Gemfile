source "https://rubygems.org"
gem "fastlane"
# json 2.21.1 (frisch kompilierte, unsignierte native Extension) wird von der
# Windows-Application-Control-Richtlinie blockiert (parser.so LoadError). Auf die
# von Ruby mitgelieferte, signierte Default-Gem 2.18.0 pinnen (erfuellt json < 3.0.0).
gem "json", "2.18.0"
